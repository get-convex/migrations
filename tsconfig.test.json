{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@convex-dev/migrations": ["./src/client/index.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "example/src/**/*.ts",
    "example/src/**/*.tsx",
    "example/convex/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "**/_generated"]
}
